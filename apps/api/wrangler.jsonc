{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "maeterna-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "maeterna",
      "database_id": "37009e7c-aaf6-4583-b1f2-c37c15484e9b",
      "migrations_dir": "drizzle/migrations",
    },
  ],
  "vars": {
    "SUPER_ADMIN_EMAIL": "devjaggernauth@gmail.com",
  },
}
