# Copy to .dev.vars and fill in real values (never commit .dev.vars — it's gitignored).

# drizzle-kit credentials (used by db:generate/db:migrate/db:studio only, not the Worker runtime)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Worker runtime
SUPER_ADMIN_EMAIL=
BETTER_AUTH_URL=http://localhost:8787/api/auth
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Local dev only — must never be set in production (see src/lib/auth.ts).
# With LOCAL_DEV_ONLY_SIGNAL set, magic-link URLs print to this terminal
# instead of sending real email. Set LOCAL_EMAIL_MODE=send to test real
# delivery through Resend locally.
LOCAL_DEV_ONLY_SIGNAL=true
LOCAL_EMAIL_MODE=console
